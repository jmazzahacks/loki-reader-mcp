# Loki server URL (required)
LOKI_URL=https://loki.example.com

# Basic auth credentials (optional, only needed if Loki is behind an auth proxy)
LOKI_USER=myuser
LOKI_PASS=mypassword

# Path to CA certificate PEM file (optional, for Loki servers using self-signed SSL certs)
LOKI_CA_CERT=/path/to/ca.pem

# Multi-tenant org ID (optional, only needed for shared Loki instances where
# multiple teams/orgs are isolated by tenant ID via the X-Scope-OrgID header.
# If you're running your own Loki instance, you almost certainly don't need this.)
LOKI_ORG_ID=tenant-1

# MCP transport mode: "stdio" for local dev, "sse" for Docker/remote
# (default: stdio if not set)
MCP_TRANSPORT=sse

# FastMCP network settings (only used with SSE transport)
# FASTMCP_HOST=0.0.0.0
# FASTMCP_PORT=8000
